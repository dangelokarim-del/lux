# ============================================================================
#  LUXA environment. Copy to `.env.local` and fill in to go from demo → live.
#  With NONE of these set, the app runs in fully-working in-memory demo mode.
#  Set the Supabase trio and it switches to the real backend + realtime.
# ============================================================================

# ── Supabase · Database / Auth / Realtime ──────────────────────────────────
# supabase.com → New project → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Settings → API → service_role (server-only, NEVER exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI · guest message → structured task ───────────────────────────────
# Optional: without it, the deterministic extractor is used as a fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── WhatsApp Cloud API ─────────────────────────────────────────────────────
# Meta for Developers → WhatsApp → API setup.
# Multi-tenant: each organization's number(s) live in the `whatsapp_accounts`
# table (phone_number_id → organization_id); the webhook routes by that id, so
# WHATSAPP_PHONE_NUMBER_ID here is only the default/first number for send.
WHATSAPP_VERIFY_TOKEN=        # any string you choose; reused in the webhook config
WHATSAPP_ACCESS_TOKEN=        # permanent token for sending replies
WHATSAPP_PHONE_NUMBER_ID=     # the business phone number id (register it in whatsapp_accounts too)
WHATSAPP_APP_SECRET=          # App → Settings → Basic (enables payload signature check)
